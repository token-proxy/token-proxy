# ── 必填 ──

# PostgreSQL 连接字符串
DATABASE_URL=postgres://token_proxy:token_proxy@localhost:5432/token_proxy

# JWT 签名密钥（生产环境请使用随机字符串）
JWT_SECRET=dev-secret-change-in-production

# AES-256-GCM 加密密钥（64 位十六进制 = 32 字节，用于加密存储 API 账号 Key）
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── 可选 ──

# HTTP 服务监听端口，默认 3000
SERVER_PORT=3000

# 日志级别（trace / debug / info / warn / error），默认 info
LOG_LEVEL=debug

# 分区检查间隔（秒），默认 3600（1 小时）
PARTITION_CHECK_INTERVAL_SECS=3600

# 提前创建未来分区月数，默认 1
PARTITION_PREMAKE_MONTHS=1

# 日志分区保留月数（环境变量默认值，运行时可通过管理后台动态修改），默认 12
PARTITION_RETENTION_MONTHS=12
